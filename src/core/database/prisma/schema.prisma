// NTG Modular Platform — single schema, logical sections per bundle
// @auth-membership | @tournaments-leagues | @socials-gallery

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── Enums ───────────────────────────────────────────────────────────────────

enum UserRole {
  PLAYER
  MODERATOR
  ADMIN
}

enum GameSlug {
  VALORANT
  CS2
  EA_FC26
  OTHER
}

enum TournamentStatus {
  DRAFT
  UPCOMING
  REGISTRATION_OPEN
  IN_PROGRESS
  COMPLETED
  CANCELLED
  AUCTION_OPEN
  AUCTION_LIVE
  AUCTION_COMPLETED
}

enum BracketType {
  SINGLE_ELIMINATION
  DOUBLE_ELIMINATION
  ROUND_ROBIN
  SWISS
  GSL
  GROUP_PLAYOFFS
  LEAGUE
  HYBRID
}

enum TournamentFormat {
  AUCTION
  STANDARD
  SOLO
  DUO
}

enum MatchStatus {
  SCHEDULED
  LIVE
  COMPLETED
  WALKOVER
  BYE
}

enum ParticipantType {
  USER
  TEAM
}

enum PlacementRole {
  CHAMPION
  RUNNER_UP
  THIRD
  MVP
}

enum LeaderboardScope {
  TOWN
  SEASON
  ALL_TIME
}

enum RegistrationStatus {
  PENDING
  APPROVED
  REJECTED
}

enum PlayedGame {
  VALORANT
  CS2
}

enum RegistrationParticipantRole {
  CAPTAIN
  CO_CAPTAIN
  PLAYER
}

enum ValorantRole {
  DUELIST
  INITIATOR
  CONTROLLER
  SENTINEL
  FLEX
}

enum MomentsDisplayMode {
  BLEND
  CAROUSEL
}

enum UserActivityAction {
  SIGNUP
  LEAVE
  PROFILE_UPDATE
  RIOT_LINK
  RIOT_UNLINK
  STEAM_LINK
  STEAM_UNLINK
  TOURNAMENT_REGISTER
  TOURNAMENT_UNREGISTER
  LISTING_APPLY
}

enum RosterTeamStatus {
  ACTIVE
  RECRUITING
}

enum ListingType {
  JOB
  ROSTER_TRYOUT
}

enum ListingStatus {
  DRAFT
  OPEN
  CLOSED
}

enum ListingFieldType {
  SECTION_HEADING
  DESCRIPTION
  SHORT_TEXT
  LONG_TEXT
  SINGLE_CHOICE
  MULTIPLE_CHOICE
  DROPDOWN
  LINEAR_SCALE
  MULTIPLE_CHOICE_GRID
  CHECKBOX_GRID
  DATE
  TIME
  FILE_UPLOAD
}

enum GamepassCategory {
  PLAYSTATION
  PC
}

enum HostOfferingType {
  SPONSORSHIP
  BIRTHDAY
  PRIVATE_EVENT
}

// ─── @auth-membership ────────────────────────────────────────────────────────

model User {
  id                 String    @id @default(cuid())
  accountId          String?   @unique
  email              String?   @unique
  emailVerified      DateTime?
  name               String?
  image              String?
  passwordHash       String?
  phone              String?   @unique
  dateOfBirth        DateTime? @db.Date
  olympusId          String?
  olympusIdKey       String?   @unique
  riotPuuid          String?   @unique
  riotGameName       String?
  riotTagLine        String?
  riotRegion         String?
  riotPlayerCard     String?
  riotPlayerCardWide String?
  steamId64          String?   @unique
  steamProfileUrl    String?
  steamPersonaName   String?
  steamAvatarUrl     String?
  cs2HoursPlayed     Float?
  steamLinkedAt      DateTime?
  signupCompleted    Boolean   @default(false)
  role               UserRole  @default(PLAYER)
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  accounts      Account[]
  sessions      Session[]
  playerProfile PlayerProfile?
  emailOtps     EmailOtp[]

  registrations           TournamentRegistration[]
  partnerRegistrations    TournamentRegistration[]  @relation("RegistrationPartner")
  matchSlots              MatchParticipant[]
  placements              TournamentPlacement[]
  leaderboard             LeaderboardEntry[]
  leaderboardRankAudits   LeaderboardRankAuditLog[]
  captainedTeams          TournamentTeam[]          @relation("TeamCaptain")
  coCaptainedTeams        TournamentTeam[]          @relation("TeamCoCaptain")
  teamPlayers             TournamentTeamPlayer[]
  adminAuditLogs          AdminAuditLog[]
  userActivityLogs        UserActivityLog[]
  platformSettingsUpdated PlatformSetting[]         @relation("PlatformSettingUpdatedBy")
  rosterPlayers           RosterPlayer[]
  listingApplications     ListingApplication[]
}

model EmailOtp {
  id        String   @id @default(cuid())
  email     String
  codeHash  String
  expiresAt DateTime
  attempts  Int      @default(0)
  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@index([email, expiresAt])
}

/**
 * Step-1 signup data held until email OTP is verified — no User row yet.
 */
model PendingSignup {
  id           String   @id @default(cuid())
  email        String   @unique
  phone        String   @unique
  passwordHash String
  displayName  String
  dateOfBirth  DateTime @db.Date
  olympusId    String
  olympusIdKey String   @unique
  expiresAt    DateTime
  createdAt    DateTime @default(now())

  @@index([expiresAt])
}

model Account {
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([provider, providerAccountId])
}

model Session {
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@id([identifier, token])
}

model PlayerProfile {
  id                 String         @id @default(cuid())
  userId             String         @unique
  user               User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  displayName        String
  usernameKey        String         @unique
  town               String         @default("Mangaluru")
  bio                String?
  playedGames        PlayedGame[]   @default([])
  valorantRoles      ValorantRole[] @default([])
  cs2PeakPremierRank String?
  cs2FaceitRank      String?
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt

  gameLinks GameIdentity[]
}

model GameIdentity {
  id         String        @id @default(cuid())
  profileId  String
  profile    PlayerProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  game       GameSlug
  platform   String
  externalId String
  verified   Boolean       @default(false)

  @@unique([profileId, game, platform])
}

// ─── @tournaments-leagues ──────────────────────────────────────────────────

model Season {
  id          String       @id @default(cuid())
  label       String
  startsAt    DateTime?
  endsAt      DateTime?
  tournaments Tournament[]
}

model Tournament {
  id                   String            @id @default(cuid())
  slug                 String            @unique
  name                 String
  game                 GameSlug
  gameLabel            String?
  seasonId             String?
  season               Season?           @relation(fields: [seasonId], references: [id])
  status               TournamentStatus  @default(DRAFT)
  format               BracketType?
  registrationFormat   TournamentFormat?
  // Auction economy (admin-controlled; points/rank prices live in the auction app)
  coCaptainSlots       Int               @default(0)
  startingBudget       Int               @default(150)
  rosterSize           Int               @default(5)
  minBidIncrement      Int               @default(1)
  auctionStartsAt      DateTime?
  auctionEndsAt        DateTime?
  // Competition format group settings (used by GSL / GROUP_PLAYOFFS)
  groupCount           Int?
  teamsPerGroup        Int?
  advancePerGroup      Int?
  // Valorant auction rank -> points table: [{ "rank": "Diamond", "floor": 8 }, ...]
  rankPoints           Json?
  description          String?
  posterUrl            String?
  hubBannerUrl         String?
  hubCarouselImages    Json?
  showOnEsportsHub     Boolean           @default(false)
  prizePool            Decimal?          @db.Decimal(10, 2)
  prizeNotes           String?
  prizeSplit           Json?
  startsAt             DateTime?
  endsAt               DateTime?
  registrationOpensAt  DateTime?
  registrationClosesAt DateTime?
  autoManageStatus     Boolean           @default(false)
  registrationUrl      String?
  hideAfter            DateTime?
  bracketUrl           String?
  rulebookUrl          String?
  teams                Json?
  createdAt            DateTime          @default(now())
  updatedAt            DateTime          @updatedAt

  bracket         Bracket?
  tournamentTeams TournamentTeam[]
  registrations   TournamentRegistration[]
  placements      TournamentPlacement[]
}

model TournamentTeam {
  id                   String                   @id @default(cuid())
  tournamentId         String
  tournament           Tournament               @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  name                 String
  seed                 Int?
  sortOrder            Int                      @default(0)
  captainUserId        String?
  captain              User?                    @relation("TeamCaptain", fields: [captainUserId], references: [id], onDelete: SetNull)
  coCaptainUserId      String?
  coCaptain            User?                    @relation("TeamCoCaptain", fields: [coCaptainUserId], references: [id], onDelete: SetNull)
  logoUrl              String?
  sourceRegistrationId String?                  @unique
  createdAt            DateTime                 @default(now())
  updatedAt            DateTime                 @updatedAt
  players              TournamentTeamPlayer[]
  registrations        TournamentRegistration[]

  @@index([tournamentId, sortOrder])
}

model TournamentTeamPlayer {
  id              String                  @id @default(cuid())
  teamId          String
  team            TournamentTeam          @relation(fields: [teamId], references: [id], onDelete: Cascade)
  userId          String?
  user            User?                   @relation(fields: [userId], references: [id], onDelete: SetNull)
  registrationId  String?                 @unique
  registration    TournamentRegistration? @relation(fields: [registrationId], references: [id], onDelete: SetNull)
  displayName     String
  riotGameName    String?
  riotTagLine     String?
  valorantRoles   Json?
  peakPremierRank String?
  sortOrder       Int                     @default(0)
  createdAt       DateTime                @default(now())

  @@index([teamId, sortOrder])
  @@index([registrationId])
}

model TournamentRegistration {
  id                      String                      @id @default(cuid())
  tournamentId            String
  tournament              Tournament                  @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  userId                  String
  user                    User                        @relation(fields: [userId], references: [id], onDelete: Cascade)
  participantRole         RegistrationParticipantRole @default(PLAYER)
  teamId                  String?
  team                    TournamentTeam?             @relation(fields: [teamId], references: [id], onDelete: SetNull)
  teamName                String?
  partnerName             String?
  partnerUserId           String?
  partner                 User?                       @relation("RegistrationPartner", fields: [partnerUserId], references: [id], onDelete: SetNull)
  snapshotPartnerUsername String?
  snapshotOlympusId       String?
  snapshotDateOfBirth     DateTime?                   @db.Date
  snapshotAccountId       String?
  snapshotDisplayName     String?
  snapshotRiotId          String?
  snapshotPhone           String?
  snapshotRankTier        String?
  snapshotRankTierId      Int?
  snapshotValorantRoles   Json?
  snapshotCs2PeakPremier  String?
  snapshotCs2FaceitRank   String?
  snapshotSteamId64       String?
  snapshotCs2Hours        Float?
  status                  RegistrationStatus          @default(APPROVED)
  createdAt               DateTime                    @default(now())
  teamPlayerRows          TournamentTeamPlayer[]

  @@unique([tournamentId, userId])
  @@index([tournamentId, participantRole])
  @@index([teamId])
}

model Bracket {
  id           String      @id @default(cuid())
  tournamentId String      @unique
  tournament   Tournament  @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  type         BracketType
  totalRounds  Int
  matches      Match[]
}

model Match {
  id                 String             @id @default(cuid())
  bracketId          String
  bracket            Bracket            @relation(fields: [bracketId], references: [id], onDelete: Cascade)
  roundNumber        Int
  positionInRound    Int
  bracketSide        String?
  status             MatchStatus        @default(SCHEDULED)
  scheduledAt        DateTime?
  nextWinnerMatchId  String?
  nextLoserMatchId   String?
  nextWinnerMatch    Match?             @relation("WinnerAdvance", fields: [nextWinnerMatchId], references: [id], onDelete: SetNull)
  nextLoserMatch     Match?             @relation("LoserAdvance", fields: [nextLoserMatchId], references: [id], onDelete: SetNull)
  winnerAdvancesFrom Match[]            @relation("WinnerAdvance")
  loserAdvancesFrom  Match[]            @relation("LoserAdvance")
  participants       MatchParticipant[]
  result             MatchResult?

  @@unique([bracketId, roundNumber, positionInRound, bracketSide])
}

model MatchParticipant {
  id              String          @id @default(cuid())
  matchId         String
  match           Match           @relation(fields: [matchId], references: [id], onDelete: Cascade)
  slot            Int
  participantType ParticipantType
  userId          String?
  user            User?           @relation(fields: [userId], references: [id], onDelete: SetNull)
  teamLabel       String?
  seed            Int?

  @@unique([matchId, slot])
}

model MatchResult {
  id           String   @id @default(cuid())
  matchId      String   @unique
  match        Match    @relation(fields: [matchId], references: [id], onDelete: Cascade)
  winnerSlot   Int
  scoreSummary String?
  completedAt  DateTime @default(now())
}

model TournamentPlacement {
  id           String        @id @default(cuid())
  tournamentId String
  tournament   Tournament    @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  role         PlacementRole
  userId       String?
  user         User?         @relation(fields: [userId], references: [id], onDelete: SetNull)
  teamLabel    String?

  @@unique([tournamentId, role])
}

model LeaderboardEntry {
  id             String           @id @default(cuid())
  game           GameSlug
  scope          LeaderboardScope @default(TOWN)
  seasonId       String?
  userId         String
  user           User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  points         Int              @default(0)
  wins           Int              @default(0)
  losses         Int              @default(0)
  mmr            Int?
  premierRating  Int?
  rankTier       String?
  rankTierId     Int?
  peakMmr        Int?
  peakRr         Int?
  peakRankTier   String?
  peakRankTierId Int?
  peakAct        String?
  currentAct     String?
  rank           Int?
  lastSyncedAt   DateTime?
  updatedAt      DateTime         @updatedAt

  @@unique([game, scope, seasonId, userId])
}

enum LeaderboardSyncSource {
  CRON
  MANUAL
  PROFILE
  RIOT_LINK
  REGISTRATION
  ADMIN_MEMBER
  HOURLY_CRON
}

enum LeaderboardRefreshRunStatus {
  RUNNING
  COMPLETE
  ERROR
  SKIPPED
}

enum LeaderboardRefreshRunKind {
  DAILY
  HOURLY
}

/**
 * Cursor-based full leaderboard refresh (daily GHA or hourly staging).
 */
model LeaderboardRefreshRun {
  id                 String                      @id @default(cuid())
  kind               LeaderboardRefreshRunKind   @default(HOURLY)
  status             LeaderboardRefreshRunStatus @default(RUNNING)
  startedAt          DateTime                    @default(now())
  finishedAt         DateTime?
  durationMs         Int?
  totalPlayers       Int                         @default(0)
  successCount       Int                         @default(0)
  failedCount        Int                         @default(0)
  henrikRequestCount Int                         @default(0)
  cursorUserId       String?
  errorMessage       String?
  createdAt          DateTime                    @default(now())
  updatedAt          DateTime                    @updatedAt

  @@index([status, startedAt])
  @@index([kind, status, startedAt])
}

/**
 * Rank change history from Henrik sync (cron, manual refresh, profile, etc.).
 */
model LeaderboardRankAuditLog {
  id                 String                @id @default(cuid())
  userId             String
  user               User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  riotGameName       String?
  riotTagLine        String?
  source             LeaderboardSyncSource
  runId              String?
  adminId            String?
  previousRankTier   String?
  previousRankTierId Int?
  previousMmr        Int?
  newRankTier        String?
  newRankTierId      Int?
  newMmr             Int?
  changed            Boolean               @default(false)
  error              String?
  createdAt          DateTime              @default(now())

  @@index([userId, createdAt])
  @@index([source, createdAt])
  @@index([runId])
  @@index([createdAt])
}

// ─── @socials-gallery ───────────────────────────────────────────────────────

model GallerySource {
  id       String        @id @default(cuid())
  platform String
  handle   String
  active   Boolean       @default(true)
  items    GalleryItem[]

  @@unique([platform, handle])
}

model GalleryItem {
  id           String        @id @default(cuid())
  sourceId     String
  source       GallerySource @relation(fields: [sourceId], references: [id], onDelete: Cascade)
  externalId   String
  mediaType    String
  embedUrl     String?
  thumbnailUrl String?
  caption      String?
  publishedAt  DateTime?
  pinned       Boolean       @default(false)

  @@unique([sourceId, externalId])
}

model MomentsFeaturedDeck {
  id          String                 @id @default(cuid())
  slug        String                 @unique
  eyebrow     String
  title       String
  subtitle    String
  displayMode MomentsDisplayMode     @default(BLEND)
  active      Boolean                @default(true)
  sortOrder   Int                    @default(0)
  createdAt   DateTime               @default(now())
  updatedAt   DateTime               @updatedAt
  images      MomentsFeaturedImage[]
}

model MomentsFeaturedImage {
  id        String              @id @default(cuid())
  deckId    String
  deck      MomentsFeaturedDeck @relation(fields: [deckId], references: [id], onDelete: Cascade)
  url       String
  alt       String
  caption   String?
  sortOrder Int                 @default(0)

  @@index([deckId, sortOrder])
}

model SocialReelPost {
  id        String   @id @default(cuid())
  reelUrl   String   @unique
  coverUrl  String?
  caption   String?
  sortOrder Int      @default(0)
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

/**
 * Tamper-evident log of admin mutations (no PII in metadata).
 */
model AdminAuditLog {
  id        String   @id @default(cuid())
  adminId   String
  admin     User     @relation(fields: [adminId], references: [id], onDelete: Cascade)
  action    String
  target    String?
  metadata  Json?
  createdAt DateTime @default(now())

  @@index([adminId, createdAt])
  @@index([action, createdAt])
}

/**
 * Player/member activity trail (signup, links, tournament register, etc.).
 */
model UserActivityLog {
  id        String             @id @default(cuid())
  userId    String?
  user      User?              @relation(fields: [userId], references: [id], onDelete: SetNull)
  email     String?
  name      String?
  action    UserActivityAction
  target    String?
  details   String?
  metadata  Json?
  createdAt DateTime           @default(now())

  @@index([userId, createdAt])
  @@index([action, createdAt])
  @@index([createdAt])
}

/**
 * Platform-wide settings (e.g. current Valorant act for rank sync).
 */
model PlatformSetting {
  key         String   @id
  value       String
  updatedAt   DateTime @updatedAt
  updatedById String?
  updatedBy   User?    @relation("PlatformSettingUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)

  @@index([updatedAt])
}

// ─── @lounge-commerce (passes, host offerings) ───────────────────────────────

model GamepassPlan {
  id              String           @id @default(cuid())
  slug            String           @unique
  category        GamepassCategory
  title           String
  subtitle        String?
  description     String?
  priceDay        Int?
  priceNight      Int?
  priceSingle     Int?
  priceController Int?
  validityText    String?
  timeWindowText  String?
  badge           String?
  featuredOnHome  Boolean          @default(false)
  inquiryOnly     Boolean          @default(false)
  sortOrder       Int              @default(0)
  active          Boolean          @default(true)
  whatsappMessage String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  @@index([category, active, sortOrder])
  @@index([featuredOnHome, category])
}

model HostOffering {
  id         String           @id @default(cuid())
  type       HostOfferingType @unique
  title      String
  summary    String
  body       String?
  highlights Json?
  active     Boolean          @default(true)
  updatedAt  DateTime         @updatedAt
}

model SponsorLogo {
  id         String  @id @default(cuid())
  name       String
  logoUrl    String
  websiteUrl String?
  sortOrder  Int     @default(0)
  active     Boolean @default(true)

  @@index([active, sortOrder])
}

// ─── @roster-listings (NTG roster + job/tryout listings) ─────────────────────

model RosterTeam {
  id               String           @id @default(cuid())
  gameKey          String           @unique
  gameLabel        String
  status           RosterTeamStatus @default(RECRUITING)
  benefitsMarkdown String?
  sortOrder        Int              @default(0)
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  players RosterPlayer[]

  @@index([sortOrder])
}

model RosterPlayer {
  id           String     @id @default(cuid())
  rosterTeamId String
  rosterTeam   RosterTeam @relation(fields: [rosterTeamId], references: [id], onDelete: Cascade)
  userId       String
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  roleLabel    String?
  bio          String?
  sortOrder    Int        @default(0)
  createdAt    DateTime   @default(now())

  @@unique([rosterTeamId, userId])
  @@index([rosterTeamId, sortOrder])
}

model Listing {
  id          String        @id @default(cuid())
  slug        String        @unique
  type        ListingType
  title       String
  description String?
  gameKey     String?
  gameLabel   String?
  status      ListingStatus @default(DRAFT)
  sortOrder   Int           @default(0)
  rulebookUrl String?
  tryoutOpensAt    DateTime?
  tryoutClosesAt   DateTime?
  tryoutOpenDays   Int?
  autoManageTryout Boolean       @default(false)
  tryoutRepeatDays Int?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  applications ListingApplication[]
  formFields   ListingFormField[]

  @@index([status, type, sortOrder])
}

model ListingFormField {
  id        String           @id @default(cuid())
  listingId String
  listing   Listing          @relation(fields: [listingId], references: [id], onDelete: Cascade)
  sortOrder Int              @default(0)
  fieldType ListingFieldType
  label     String
  helpText  String?
  required  Boolean          @default(false)
  options   Json?
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  @@index([listingId, sortOrder])
}

model ListingApplication {
  id                    String             @id @default(cuid())
  listingId             String
  listing               Listing            @relation(fields: [listingId], references: [id], onDelete: Cascade)
  userId                String
  user                  User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  status                RegistrationStatus @default(PENDING)
  message               String?
  responses             Json?
  snapshotDisplayName   String?
  snapshotPhone         String?
  snapshotRiotId        String?
  snapshotRankTier      String?
  snapshotRankTierId    Int?
  snapshotValorantRoles Json?
  snapshotSteamId64     String?
  snapshotCs2Hours      Float?
  snapshotCs2PeakPremier String?
  snapshotCs2FaceitRank String?
  snapshotOlympusId     String?
  snapshotDateOfBirth   DateTime?          @db.Date
  createdAt             DateTime           @default(now())
  updatedAt             DateTime           @updatedAt

  @@unique([listingId, userId])
  @@index([listingId, createdAt])
}
