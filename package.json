{
  "name": "ntg-lounge",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "predev": "prisma generate --schema=src/core/database/prisma/schema.prisma",
    "dev": "next dev",
    "build": "prisma generate --schema=src/core/database/prisma/schema.prisma && next build",
    "start": "next start",
    "lint": "eslint",
    "test": "vitest run",
    "test:unit": "vitest run tests/unit",
    "test:smoke": "vitest run tests/smoke",
    "test:a11y": "vitest run tests/a11y",
    "test:load": "node scripts/load-test.mjs",
    "test:watch": "vitest",
    "postinstall": "prisma generate --schema=src/core/database/prisma/schema.prisma",
    "db:generate": "prisma generate --schema=src/core/database/prisma/schema.prisma",
    "db:push": "dotenv -e .env.local -- prisma db push --schema=src/core/database/prisma/schema.prisma && prisma generate --schema=src/core/database/prisma/schema.prisma",
    "db:migrate": "dotenv -e .env.local -- prisma migrate dev --schema=src/core/database/prisma/schema.prisma && prisma generate --schema=src/core/database/prisma/schema.prisma",
    "db:migrate:deploy": "dotenv -e .env.local -- prisma migrate deploy --schema=src/core/database/prisma/schema.prisma && prisma generate --schema=src/core/database/prisma/schema.prisma",
    "db:seed": "dotenv -e .env.local -- tsx src/core/database/seed.ts",
    "db:seed:dev": "dotenv -e .env.local -v SEED_DEV_MOCK_DATA=1 -- tsx src/core/database/seed.ts",
    "db:migrate-static": "dotenv -e .env.local -- tsx scripts/migrate-static-to-db.ts",
    "import:moments": "node scripts/import-moments-photos.mjs",
    "sync:reel-covers": "dotenv -e .env.local -- node scripts/sync-reel-covers.mjs"
  },
  "dependencies": {
    "@auth/prisma-adapter": "^2.11.2",
    "@aws-sdk/client-s3": "^3.1071.0",
    "@prisma/client": "^6.19.3",
    "@types/jsonwebtoken": "^9.0.10",
    "bcryptjs": "^3.0.3",
    "framer-motion": "^12.40.0",
    "jsonwebtoken": "^9.0.3",
    "next": "16.2.9",
    "next-auth": "^5.0.0-beta.31",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "resend": "^6.12.4",
    "simple-icons": "^16.23.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.0",
    "@tailwindcss/postcss": "^4",
    "@types/bcryptjs": "^3.0.0",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "dotenv-cli": "^11.0.0",
    "eslint": "^9",
    "eslint-config-next": "16.2.9",
    "prisma": "^6.19.3",
    "tailwindcss": "^4",
    "tsx": "^4.22.4",
    "typescript": "^5",
    "vitest": "^4.1.9"
  },
  "prisma": {
    "schema": "src/core/database/prisma/schema.prisma",
    "seed": "tsx src/core/database/seed.ts"
  },
  "overrides": {
    "postcss": "^8.5.10"
  }
}
