{
  "compilerOptions": {
    "target": "ES2017",
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@/*": ["./src/*"],
      "@core/*": ["./src/core/*"],
      "@auth-membership/*": ["./src/modules/auth-membership/*"],
      "@tournaments-leagues/*": ["./src/modules/tournaments-leagues/*"],
      "@socials-gallery/*": ["./src/modules/socials-gallery/*"],
      "@landing-home/*": ["./src/modules/landing-home/*"],
      "@lounge-commerce/*": ["./src/modules/lounge-commerce/*"],
      "@roster-listings/*": ["./src/modules/roster-listings/*"],
      "@time-limited-qa/*": ["./src/modules/time-limited-qa/*"]
    }
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts",
    "**/*.mts"
  ],
  "exclude": ["node_modules", "scripts", "playwright.config.ts", "tests/**/*.spec.ts"]
}
