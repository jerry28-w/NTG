# Public
NEXT_PUBLIC_SITE_URL=https://www.ntgesports.com
NEXT_PUBLIC_WHATSAPP_NUMBER=
NEXT_PUBLIC_INSTAGRAM_URL=https://instagram.com/ntg_lounge
NEXT_PUBLIC_DISCORD_URL=
NEXT_PUBLIC_GOOGLE_MAPS_EMBED_URL=
NEXT_PUBLIC_GOOGLE_MAPS_LINK=
NEXT_PUBLIC_GOOGLE_MAPS_EMBED_URL_RAW=
NEXT_PUBLIC_ALLOW_PAST_TOURNAMENT_CLICKS=0
# Set to 1 to show homepage Plans & Host section (#plans) in preview/local
NEXT_PUBLIC_SHOW_PLANS_SECTION=0
# Set to 1 only on a fresh local DB — never on production (creates mock users + demo cups)
SEED_DEV_MOCK_DATA=0
NEXT_PUBLIC_SPONSOR_EMAIL=

# Set to 0 in production once cups live in admin/DB (see scripts/migrate-static-to-db.ts)
NEXT_PUBLIC_USE_STATIC_TOURNAMENT_DETAIL=0

# Database (Neon)
# After schema changes: npm run db:push (local) or db:migrate:deploy (prod), then restart npm run dev.
DATABASE_URL=postgresql://USER:PASSWORD@ep-xxx-pooler.region.aws.neon.tech/neondb?sslmode=require
DIRECT_URL=postgresql://USER:PASSWORD@ep-xxx.region.aws.neon.tech/neondb?sslmode=require

# Auth
AUTH_SECRET=
AUTH_URL=http://localhost:3000
# Bootstrap admin before first signup (comma-separated). User must sign up/login with this email.
ADMIN_EMAILS=

# Email (Resend)
# Free sandbox (onboarding@resend.dev) only sends to your Resend account email.
# For real signups, verify a domain at resend.com/domains and set EMAIL_FROM to that domain.
RESEND_API_KEY=
EMAIL_FROM=NTG Lounge <onboarding@resend.dev>

# Leaderboard rank sync — daily via GitHub Actions (see docs/DAILY_LEADERBOARD_REFRESH.md)
# Set to 1 in production. Recipient: LEADERBOARD_SYNC_NOTIFY_EMAIL (or first ADMIN_EMAILS).
LEADERBOARD_SYNC_NOTIFY=0
LEADERBOARD_SYNC_NOTIFY_EMAIL=

# Henrik.dev (HENRIKDEV also accepted as alias)
HENRIKDEV_API_KEY=
# Required for leaderboard rank sync (cron + admin manual refresh). Example: e11a3
VALORANT_CURRENT_ACT=

# Steam Web API (CS2 profile validation)
STEAM_WEB_API_KEY=

# Cron (Bearer token for /api/cron/* — Vercel Hobby: max 2 daily crons; reel covers via npm run sync:reel-covers or external scheduler)
CRON_SECRET=

# GitHub Actions dispatch (Vercel cron triggers daily leaderboard workflow at 2:30 AM IST)
# Fine-grained PAT on this repo with Actions: Read and write
GITHUB_ACTIONS_DISPATCH_TOKEN=
# Optional overrides (defaults: Vibhubalan/NTG, main)
# GITHUB_ACTIONS_REPO=Vibhubalan/NTG
# GITHUB_ACTIONS_REF=main

# Challonge (bracket sync)
CHALLONGE_API_KEY=

# Auction app (standalone draft tool). AUCTION_JWT_SECRET must match the auction app's JWT_SECRET exactly.
AUCTION_URL=http://localhost:3001
AUCTION_JWT_SECRET=

# Google Places
GOOGLE_PLACES_API_KEY=
GOOGLE_PLACE_ID=

# YouTube
YOUTUBE_CHANNEL_ID=
YOUTUBE_CHANNEL_URL=https://www.youtube.com/@NTGLounge

# Instagram reels
INSTAGRAM_REEL_URLS=
INSTAGRAM_REEL_THUMBNAILS=
INSTAGRAM_REEL_CAPTIONS=

# S3-compatible object storage (Cloudflare R2, etc.)
S3_BUCKET=
S3_REGION=auto
S3_PUBLIC_URL=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_ENDPOINT=

# Rate limiting (recommended for production — Upstash Redis)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
